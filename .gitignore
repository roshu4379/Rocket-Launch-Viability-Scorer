# Local .terraform directories containing downloaded providers and modules
.terraform/

# Distributed planetary-scale lock files generated by modern Terraform versions
.terraform.lock.hcl

# Local state history files and backups
*.tfstate
*.tfstate.backup

# Terraform crash logs
crash.log
crash.*.log

# Local variable definitions files (often contain sensitive credentials or keys)
*.tfvars
*.tfvars.json
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration credentials file
.terraformrc
terraform.rc